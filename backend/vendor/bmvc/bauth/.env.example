# Configuration BAuth

# JWT Secret Key - CHANGEZ CETTE VALEUR EN PRODUCTION
AUTH_JWT_SECRET=your-super-secret-key-change-me-in-production

# JWT Settings
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_EXPIRES_IN=3600
AUTH_JWT_REFRESH_EXPIRES_IN=604800

# Password Algorithm
AUTH_PASSWORD_ALGORITHM=2y  # 2y pour bcrypt
AUTH_PASSWORD_COST=12

# Session Settings
AUTH_SESSION_NAME=bauth_session
AUTH_SESSION_LIFETIME=7200

# 2FA Settings
AUTH_2FA_ENABLED=false
AUTH_2FA_WINDOW=1

# Database (pour les exemples)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bauth_db
DB_USER=root
DB_PASSWORD=

# Application Settings
APP_ENV=development
APP_DEBUG=true
