{
  "name": "bmvc/bauth",
  "description": "A complete, framework-agnostic PHP authentication library",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Josue Bondo",
      "email": "josuebondojw@gmail.com"
    }
  ],
  "homepage": "https://github.com/josuebondo/bauth",
  "support": {
    "issues": "https://github.com/josuebondo/bauth/issues",
    "source": "https://github.com/josuebondo/bauth"
  },
  "require": {
    "php": "^8.0",
    "firebase/php-jwt": "^6.0",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "phpstan/phpstan": "^1.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "Bmvc\\BAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bmvc\\BAuth\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse src/",
    "phpcs": "phpcs src/"
  },
  "keywords": [
    "authentication",
    "auth",
    "jwt",
    "security",
    "php",
    "bauth",
    "bmvc",
    "laravel",
    "symfony"
  ]
}
