# Variables d'environnement BMVC
# À remplir avec vos données

# ================================================
# APPLICATION
# ================================================
NOM_APPLICATION=BMVC
ENVIRONNEMENT=local
DEBOGAGE=true
CLE_SECRETE=your-secret-key-here
FUSEAU_HORAIRE=Europe/Paris
LOCALE=fr
URL_APPLICATION=http://localhost:8000
URL_FRONTEND =http://localhost:5173

# ================================================
# BASE DE DONNÉES
# ================================================
TYPE_CONNEXION=mysql
HOTE_BD=127.0.0.1
PORT_BD=888
NOM_BD=quantix_db
UTILISATEUR_BD=root
MOT_DE_PASSE_BD=Root

# ================================================
# CACHE & SESSION
# ================================================
PILOTE_CACHE=file
PILOTE_SESSION=file
TTL_CACHE=3600

# ================================================
# EMAIL / NOTIFICATIONS
# ================================================
PILOTE_MAIL=mail
ADRESSE_EMAIL_EXPEDITEUR=noreply@bmvc.local
NOM_EMAIL_EXPEDITEUR=Application BMVC
SERVEUR_MAIL=localhost
PORT_MAIL=587
UTILISATEUR_MAIL=
MOT_DE_PASSE_MAIL=

# ================================================
# URLS & ROUTES
# ================================================
URL_REINITIALISATION_MDP=/reinitialiser
EXPIRATION_REINITIALISATION_MDP=86400

# ================================================
# UPLOAD FICHIERS
# ================================================
REPERTOIRE_UPLOAD=public/uploads/
TAILLE_MAX_UPLOAD=2
EXTENSIONS_AUTORISEES=jpg,jpeg,png,gif,pdf,doc,docx
REPERTOIRE_TEMP_UPLOAD=storage/uploads/

# ================================================
# SMS / MESSAGING (optionnel)
# ================================================
FOURNISSEUR_SMS=twilio
COMPTE_SID_SMS=
JET_AUTH_SMS=
NUMERO_ENVOI_SMS=

# ================================================
# SERVICES
# ================================================
TTL_SERVICE_CACHE=3600
TAILLE_CHUNK_UPLOAD=1048576
PILOTE_QUEUE=database

# ================================================
# SÉCURITÉ
# ================================================
ROUNDS_BCRYPT=12
ALGO_HASH=bcrypt
AUTH_JWT_SECRET=your-jwt-secret-key-change-in-production

# Cache
CACHE_DRIVER=file

# Session
SESSION_DRIVER=file

